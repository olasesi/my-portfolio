# ============================================================
#  public/.htaccess  (XAMPP / Windows — localhost/my-portfolio/)
#  This file is the real web root.
# ============================================================

Options -Indexes -MultiViews
DirectoryIndex index.php

# ── Security Headers ─────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always unset X-Powered-By
</IfModule>

# ── Hide PHP version ──────────────────────────────────────
<IfModule mod_php8.c>
    php_flag expose_php Off
</IfModule>

# ── Block sensitive files ─────────────────────────────────
<FilesMatch "\.(env|log|sh|sql|bak|ini|pem|key|htpasswd)$">
    Require all denied
</FilesMatch>

# ── Custom Error Pages ────────────────────────────────────
ErrorDocument 400 /my-portfolio/public/errors/400.php
ErrorDocument 401 /my-portfolio/public/errors/401.php
ErrorDocument 403 /my-portfolio/public/errors/403.php
ErrorDocument 404 /my-portfolio/public/errors/404.php
ErrorDocument 500 /my-portfolio/public/errors/500.php
ErrorDocument 503 /my-portfolio/public/errors/503.php

# ── URL Rewriting ─────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /my-portfolio/public/

    # 1. Block dotfiles (but allow .htaccess itself to be read)
    RewriteRule (^|/)\.(?!htaccess) - [F,L]

    # 2. Canonical: /about.php → /about  (strip .php from URL bar)
    RewriteCond %{THE_REQUEST} \s/+my-portfolio/public/(.+?)\.php[\s?] [NC]
    RewriteRule ^ /my-portfolio/public/%1 [R=301,L]

    # 3. Skip real files and directories — serve them directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 4. Route clean URLs → .php files
    #    /my-portfolio/public/about      → about.php
    #    /my-portfolio/public/portfolio  → portfolio.php
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]

    # 5. Trailing slash removal: /about/ → /about
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /my-portfolio/public/$1 [R=301,L]
</IfModule>

# ── Browser Caching ───────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType font/woff               "access plus 1 year"
</IfModule>

# ── Gzip Compression ─────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>
