# ============================================================

# ROOT .htaccess (XAMPP / Windows — localhost/ahmed-olusesi/)

# Funnels all browser traffic into public/.

# ============================================================

Options -Indexes

RewriteEngine On
RewriteBase /ahmed-olusesi/

# ── 1. Block sensitive project files ─────────────────────

RewriteRule ^(composer\.(json|lock)|\.env._|vendor(/._)?|src(/.\*)?)$ - [F,L]

# ── 2. Already inside public/ — stop, prevent loop ───────

RewriteCond %{REQUEST_URI} ^/ahmed-olusesi/public/ [NC]
RewriteRule ^ - [L]

# ── 3. Forward everything else into public/ ──────────────

RewriteRule ^(.\*)$ public/$1 [L]
